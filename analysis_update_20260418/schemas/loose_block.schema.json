$schema: https://json-schema.org/draft/2020-12/schema
title: LooseBlock
type: object
required:
- block_id
- pair_count
- pairs
properties:
  block_id:
    type: integer
    minimum: 1
  pair_count:
    type: integer
    minimum: 1
  mean_score:
    type: number
  pairs:
    type: array
    minItems: 1
